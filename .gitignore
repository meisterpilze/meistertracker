# OS files
.DS_Store
Thumbs.db

# Dependencies
node_modules/

# Backups
backups/

# Data
data.json
*.db
*.db-wal
*.db-shm

# Runtime data (photos, calendar attachments, ad-hoc per-instance state).
# `data/photos/{YYYY}/{MM}/{report_id}/*.jpg` is written by the server when
# operators attach photos to contamination reports — these may contain
# workers' hands/badges/faces and must never be committed (GDPR).
data/

# Calendars
calendars/

# TLS certificates
certs/

# Environment
.env

# Watchdog runtime files
watchdog.pid
watchdog.log
watchdog-error.log

# Claude Code
.claude/

# Internal working / audit docs (never commit)
audit-*.md
audit-plan.md
pain-points.md
phase-*.md
i18n-report.md

# Pre-compressed static asset variants (regenerated on server startup)
*.gz
*.br
